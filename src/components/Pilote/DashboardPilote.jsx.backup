import { useState, useEffect } from 'react'
import { ChevronLeft, ChevronRight, Save, ChevronDown } from 'lucide-react'
import { useAppStore } from '../../stores/appStore'
import { useModelStore } from '../../stores/modelStore'  // ← NOUVEAU
import { calculerMasseOptimale, calculerChargeAlaire, calculerMeteo } from '../../utils/poly4'
import { resoudreSoute, calculerStatsSoute, calculerCGCible } from '../../utils/ballast'

export default function DashboardPilote() {
  const { 
  params, 
incrementParam,
decrementParam,
offset, 
incrementOffset, 
decrementOffset,
altitude,
alpha,
k_up,
selectedParam, 
selectParam 
} = useAppStore()
  
  // ← NOUVEAU : Utiliser ModelStore au lieu de SouteStore
  const { getActiveModel, getConfigForSolver } = useModelStore()
  const activeModel = getActiveModel()
  
  // Récupérer mv et surface depuis le modèle actif
  const mv = activeModel ? activeModel.masseVide / 1000 : 2.455  // Convertir g → kg
  const surface = activeModel ? activeModel.surface : 59
  
  // Récupérer la config pour le solver
  const config = activeModel ? getConfigForSolver(activeModel.id) : null
  
  const vent = params.vent
  
  // Calcul MÉTÉO (rho, rr)
  const meteo = calculerMeteo(
    params.pression,
    params.temperature,
    params.rosee,
    altitude
  )
  
  // Calcul POLY4 (masse de base)
  const masseBase = calculerMasseOptimale(vent) // kg
const densiteRel = (alt) => {
  if (alt <= 0) return 1.0
  return Math.pow(1 - 0.0065 * alt / 288.15, 5.25588)
}
const rr = densiteRel(altitude)
 
//  NOUVELLE FORMULE avec alpha, k_up et rr
const masseCible = (masseBase * alpha * k_up + (offset / 1000)) * rr
const masseCibleGrammes = masseCible * 1000
const masseVideGrammes = mv * 1000
  
  // Résolution automatique soute (avec config depuis ModelStore)
  const solution = config 
    ? resoudreSoute(masseCibleGrammes, masseVideGrammes, 0, config)
    : { gauche: {av:[], c:[], ar:[]}, droite: {av:[], c:[], ar:[]} }
  
  const stats = config 
    ? calculerStatsSoute(solution, config)
    : { masse: 0, cg: 0, asymetrie: 0, masseGauche: 0, masseDroite: 0 }
  
  // Masse ACTUELLE
  const masseActuelle = mv + (stats.masse / 1000)
  
  // Charge alaire - CORRIGÉE
  const chargeAlaire = calculerChargeAlaire(masseActuelle, surface)
  
  // CG - INVERSER LE SIGNE POUR AFFICHAGE (convention pilote)
  const cgSoute = -stats.cg // Ligne 52 : inversion du signe
  
  // Centrage cible
  const cgCible = calculerCGCible(masseActuelle, vent)
  
  // Différence CG
  const deltaCG = cgSoute - cgCible
  
  // Barographe - Obtenir les soutes depuis le modèle
  const soutes = activeModel?.soutes ? Object.values(activeModel.soutes) : []
  
  // Trier les soutes par position (AV < C < AR)
  const soutesSorted = [...soutes].sort((a, b) => {
    const posA = a.distanceBA - activeModel.cgVide
    const posB = b.distanceBA - activeModel.cgVide
    return posA - posB
  })
  
  // Mapper les soutes vers le format du barographe
  const barographeData = soutesSorted.map((soute, index) => {
    const key = ['av', 'c', 'ar'][index] || `s${index}`
    const gauche = solution.gauche[key] || []
    const droite = solution.droite[key] || []
    
    return {
      nom: soute.nom,
      couleur: soute.couleur,
      capacite: soute.capacite,
      gauche: gauche,
      droite: droite,
      materiaux: soute.materiaux || []
    }
  })
 return (
    <div className="flex flex-col h-screen overflow-hidden">
      {/* Header */}
      <div className="bg-gray-900 border-b border-gray-700 p-4">
        <div className="flex items-center justify-between mb-2">
          <button className="flex items-center gap-1 text-sm text-blue-400">
            <ChevronDown size={16} />
            <span className="font-bold">{activeModel?.nom || 'Aucun modèle'}</span>
          </button>
          <div className="text-xs text-gray-500">
            rho: {meteo.rho.toFixed(3)} {meteo.rho < 0.973 ? '(Neutre)' : ''}
          </div>
        </div>
        
        <div className="grid grid-cols-3 gap-2 text-center">
          <div>
            <div className="text-xs text-gray-400">CIBLE</div>
            <div className="text-2xl font-bold text-white">{masseCible.toFixed(3)}</div>
            <div className="text-xs text-gray-500">Poly4 {masseBase.toFixed(3)}</div>
          </div>
          
          <div>
            <div className="text-xs text-gray-400">ACTUEL</div>
            <div className="text-2xl font-bold text-green-400">{masseActuelle.toFixed(3)}</div>
            <div className="text-xs text-red-400">
              {chargeAlaire.toFixed(1)} g/dm² ({(masseCibleGrammes - masseActuelle * 1000).toFixed(0)}g)
            </div>
          </div>
          
          <div>
            <div className="text-xs text-gray-400">CG (MM)</div>
            <div className="text-2xl font-bold text-green-400">{cgSoute.toFixed(1)}</div>
            <div className="text-xs text-gray-500">
              {cgSoute.toFixed(1)}mm
              <br />
              Cible {cgCible.toFixed(1)}mm
            </div>
          </div>
        </div>
      </div>

      {/* Barographe */}
      <div className="flex-1 overflow-y-auto p-4">
        {barographeData.length === 0 ? (
          <div className="flex items-center justify-center h-full text-gray-400">
            <div className="text-center">
              <div className="text-4xl mb-2">📦</div>
              <div>Aucune soute configurée</div>
              <div className="text-sm mt-2">Va dans l'onglet Soute pour configurer</div>
            </div>
          </div>
        ) : (
          <div className="space-y-4">
            {barographeData.map((soute, index) => (
              <div key={index} className="bg-gray-800 rounded-lg p-3 border" style={{ borderColor: soute.couleur }}>
                <div className="text-sm font-semibold mb-2" style={{ color: soute.couleur }}>
                  {soute.nom}
                </div>
                
                <div className="grid grid-cols-2 gap-2">
                  <div>
                    <div className="text-xs text-gray-400 mb-1">Gauche</div>
                    <div className="flex flex-row-reverse gap-1" style={{ direction: 'ltr' }}>
                      {Array.from({ length: soute.capacite }).map((_, i) => {
                        const materiau = soute.gauche[i]
                        const couleur = materiau ? getCouleurMateriau(materiau) : '#374151'
                        return (
                          <div
                            key={i}
                            className="aspect-[3/4] rounded border border-gray-700"
                            style={{ 
                              backgroundColor: couleur,
                              width: `calc((100% - ${(soute.capacite - 1) * 4}px) / ${soute.capacite})`
                            }}
                            title={materiau || 'Vide'}
                          />
                        )
                      })}
                    </div>
                  </div>
                  
                  <div>
                    <div className="text-xs text-gray-400 mb-1 text-right">Droite</div>
                    <div className="flex gap-1">
                      {Array.from({ length: soute.capacite }).map((_, i) => {
                        const materiau = soute.droite[i]
                        const couleur = materiau ? getCouleurMateriau(materiau) : '#374151'
                        return (
                          <div
                            key={i}
                            className="aspect-[3/4] rounded border border-gray-700"
                            style={{ 
                              backgroundColor: couleur,
                              width: `calc((100% - ${(soute.capacite - 1) * 4}px) / ${soute.capacite})`
                            }}
                            title={materiau || 'Vide'}
                          />
                        )
                      })}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
      
      {/* Footer */}
      <div className="bg-gray-900 border-t border-gray-700 p-4">
        <div className="flex items-center justify-between">
          <button onClick={() => decrementParam('vent')} className="bg-gray-800 hover:bg-gray-700 p-3 rounded-lg">
            <ChevronLeft size={24} />
          </button>
          <div className="text-center flex-1">
            <div className="text-4xl font-bold text-white mb-1">{vent.toFixed(1)}</div>
            <div className="text-sm text-gray-400">VENT</div>
          </div>
          <button onClick={() => incrementParam('vent')} className="bg-gray-800 hover:bg-gray-700 p-3 rounded-lg">
            <ChevronRight size={24} />
          </button>
        </div>
      </div>
    </div>
  ) 
}

// Fonction helper pour obtenir la couleur d'un matériau
function getCouleurMateriau(nomMateriau) {
  const nom = nomMateriau.toLowerCase()
  
  if (nom.includes('tungst') || nom.includes('w')) return '#d97706' // Orange (Tungstène)
  if (nom.includes('plomb') || nom.includes('l')) return '#9ca3af'  // Gris clair (Plomb)
  if (nom.includes('laiton') || nom.includes('b')) return '#fbbf24' // Jaune (Laiton)
  if (nom.includes('lourd')) return '#b45309'  // Orange foncé
  if (nom.includes('très lourd')) return '#92400e'  // Orange très foncé
  
  return '#6b7280' // Gris par défaut
}